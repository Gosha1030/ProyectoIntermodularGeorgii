<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/swAlarm"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Alarm (inicio o travel)"/>

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/swDnd"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="No molestar (DND)"/>

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/swNotifyMonth"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Notificar 1 mes antes"/>

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/swNotifyWeek"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Notificar 1 semana antes"/>

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/swNotifyDay"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Notificar 1 día antes"/>

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/swNotifyOnDay"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Notificar el mismo día"/>

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/swNotify1h"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Notificar 1h antes"/>

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/swNotify10m"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Notificar 10m antes"/>

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/swNotify1m"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Notificar 1m antes"/>

    </LinearLayout>
</ScrollView>