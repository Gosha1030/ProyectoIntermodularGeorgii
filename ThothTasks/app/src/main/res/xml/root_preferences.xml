<?xml version="1.0" encoding="utf-8"?>
<PreferenceScreen xmlns:app="http://schemas.android.com/apk/res-auto">

    <PreferenceCategory app:title="@string/settings_general">

        <ListPreference
            app:key="pref_language"
            app:title="@string/language"
            app:entries="@array/language_entries"
            app:entryValues="@array/language_values"
            app:useSimpleSummaryProvider="true" />

        <SwitchPreferenceCompat
            app:key="pref_ask_password"
            app:title="@string/ask_password"
            app:defaultValue="true" />

    </PreferenceCategory>

    <PreferenceCategory app:title="@string/settings_tools">

        <Preference
            app:key="pref_backup"
            app:title="@string/backup" />

        <Preference
            app:key="pref_tutorial_online"
            app:title="@string/tutorial_online" />

    </PreferenceCategory>

    <PreferenceCategory app:title="@string/settings_session">

        <Preference
            app:key="pref_logout"
            app:title="@string/logout" />

    </PreferenceCategory>

</PreferenceScreen>